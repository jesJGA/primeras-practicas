Algoritmo sin_titulo
		Definir num Como Real
		
		Escribir "Ingresa un nºmero:"
		Leer num
		
		Si num > 0 Entonces
			Escribir "El nºmero es positivo"
		SiNo
			Si num < 0 Entonces
				Escribir "El nºmero es negativo"
			SiNo
				Escribir "El nºmero es cero"
			FinSi
		FinSi
FinAlgoritmo
